<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<VBox alignment="CENTER" spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.MainMenuController">
    <Label text="Подсистема производства мотоциклов" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Button text="Управление клиентами" onAction="#openClientForm"/>
    <Button text="Управление заказами" onAction="#openOrderForm"/>
    <Button text="Управление мотоциклами" onAction="#openMotorcycleForm"/>
    <Button text="Управление доставками" onAction="#openDeliveryForm"/>
    <Button text="Управление тестированием" onAction="#openTestingForm"/>
    <Button text="Управление работниками" onAction="#openWorkerForm"/>
    <Button text="Управление компонентами" onAction="#openComponentForm"/>
    <Button text="Управление материалами" onAction="#openMaterialForm"/>
    <Button text="Управление поставщиками" onAction="#openSupplierForm"/>
    <Button text="Управление менеджерами" onAction="#openManagerForm"/>
</VBox>