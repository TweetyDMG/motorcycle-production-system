<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.DeliveryFormController">
    <Label text="Управление доставками" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID доставки"/>
    <TextField fx:id="deliveryIdField"/>
    <Label text="ID мотоцикла"/>
    <TextField fx:id="motorcycleIdField"/>
    <Label text="ID клиента"/>
    <TextField fx:id="customerIdField"/>
    <Label text="Пункт назначения"/>
    <TextField fx:id="destinationField"/>
    <Button text="Создать доставку" onAction="#handleCreateDelivery"/>
    <Button text="Найти доставку" onAction="#handleFindDelivery"/>
    <Button text="Доставить мотоцикл" onAction="#handleDeliverMotorcycle"/>
    <Button text="Удалить доставку" onAction="#handleDeleteDelivery"/>
</VBox>