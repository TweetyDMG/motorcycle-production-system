<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.ProductionWorkerDashboardController">
    <Label text="Панель производственного рабочего" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="Изготовить компонент"/>
    <TextField fx:id="componentIdField" promptText="ID компонента"/>
    <Button text="Изготовить" onAction="#handleManufactureComponent"/>
</VBox>