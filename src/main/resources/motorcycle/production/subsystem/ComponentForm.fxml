<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.ComponentFormController">
    <Label text="Управление компонентами" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID компонента"/>
    <TextField fx:id="componentIdField"/>
    <Label text="Название"/>
    <TextField fx:id="nameField"/>
    <Label text="ID материала"/>
    <TextField fx:id="materialIdField"/>
    <Button text="Создать компонент" onAction="#handleCreateComponent"/>
    <Button text="Найти компонент" onAction="#handleFindComponent"/>
    <Button text="Изготовить компонент" onAction="#handleManufactureComponent"/>
    <Button text="Обновить компонент" onAction="#handleUpdateComponent"/>
    <Button text="Удалить компонент" onAction="#handleDeleteComponent"/>
</VBox>