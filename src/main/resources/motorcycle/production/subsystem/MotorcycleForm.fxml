<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.MotorcycleFormController">
    <Label text="Управление мотоциклами" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID мотоцикла"/>
    <TextField fx:id="motorcycleIdField"/>
    <Label text="Модель"/>
    <TextField fx:id="modelField"/>
    <Label text="ID компонентов (через запятую)"/>
    <TextField fx:id="componentIdsField"/>
    <Button text="Создать мотоцикл" onAction="#handleCreateMotorcycle"/>
    <Button text="Найти мотоцикл" onAction="#handleFindMotorcycle"/>
    <Button text="Собрать мотоцикл" onAction="#handleAssembleMotorcycle"/>
    <Button text="Протестировать мотоцикл" onAction="#handleTestMotorcycle"/>
    <Button text="Удалить мотоцикл" onAction="#handleDeleteMotorcycle"/>
</VBox>