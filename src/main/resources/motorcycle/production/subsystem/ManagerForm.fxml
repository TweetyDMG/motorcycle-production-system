<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.ManagerFormController">
    <Label text="Управление менеджерами" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID менеджера"/>
    <TextField fx:id="managerIdField"/>
    <Label text="Имя"/>
    <TextField fx:id="nameField"/>
    <Label text="Контактная информация"/>
    <TextField fx:id="contactInfoField"/>
    <Label text="ID заказа"/>
    <TextField fx:id="orderIdField"/>
    <Label text="Статус заказа"/>
    <TextField fx:id="orderStatusField"/>
    <Label text="ID поставщика"/>
    <TextField fx:id="supplierIdField"/>
    <Button text="Создать менеджера" onAction="#handleCreateManager"/>
    <Button text="Найти менеджера" onAction="#handleFindManager"/>
    <Button text="Управлять заказом" onAction="#handleManageOrder"/>
    <Button text="Управлять поставщиком" onAction="#handleManageSupplier"/>
    <Button text="Удалить менеджера" onAction="#handleDeleteManager"/>
</VBox>