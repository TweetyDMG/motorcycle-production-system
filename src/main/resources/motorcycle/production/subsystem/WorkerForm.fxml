<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.WorkerFormController">
    <Label text="Управление работниками" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID работника"/>
    <TextField fx:id="workerIdField"/>
    <Label text="Имя"/>
    <TextField fx:id="nameField"/>
    <Label text="Специализация"/>
    <TextField fx:id="specializationField"/>
    <Button text="Создать работника" onAction="#handleCreateWorker"/>
    <Button text="Найти работника" onAction="#handleFindWorker"/>
    <Button text="Обновить работника" onAction="#handleUpdateWorker"/>
    <Button text="Удалить работника" onAction="#handleDeleteWorker"/>
</VBox>