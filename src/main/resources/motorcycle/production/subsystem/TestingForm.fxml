<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.TestingFormController">
    <Label text="Управление тестированием" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID теста"/>
    <TextField fx:id="testIdField"/>
    <Label text="ID мотоцикла"/>
    <TextField fx:id="motorcycleIdField"/>
    <Label text="Результат"/>
    <TextField fx:id="resultField"/>
    <Label text="Проблемы"/>
    <TextField fx:id="issuesField"/>
    <Button text="Создать тест" onAction="#handleCreateTest"/>
    <Button text="Найти тест" onAction="#handleFindTest"/>
    <Button text="Выполнить тест" onAction="#handlePerformTest"/>
    <Button text="Устранить проблемы" onAction="#handleFixIssues"/>
    <Button text="Удалить тест" onAction="#handleDeleteTest"/>
</VBox>