<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.MaterialFormController">
    <Label text="Управление материалами" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID материала"/>
    <TextField fx:id="materialIdField"/>
    <Label text="Название"/>
    <TextField fx:id="nameField"/>
    <Label text="Количество"/>
    <TextField fx:id="quantityField"/>
    <Button text="Создать материал" onAction="#handleCreateMaterial"/>
    <Button text="Найти материал" onAction="#handleFindMaterial"/>
    <Button text="Обновить материал" onAction="#handleUpdateMaterial"/>
    <Button text="Удалить материал" onAction="#handleDeleteMaterial"/>
</VBox>