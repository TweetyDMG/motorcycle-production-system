<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.OrderFormController">
    <Label text="Управление заказами" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID Заказа"/>
    <TextField fx:id="orderIdField"/>
    <Label text="ID клиента"/>
    <TextField fx:id="customerIdField"/>
    <Label text="ID мотоцикла"/>
    <TextField fx:id="motorcycleIdField"/>
    <Label text="Дата заказа (YYYY-MM-DD)"/>
    <TextField fx:id="orderDateField"/>
    <Label text="Статус"/>
    <TextField fx:id="statusField"/>
    <Button text="Создать заказ" onAction="#handleCreateOrder"/>
    <Button text="Найти заказ" onAction="#handleFindOrder"/>
    <Button text="Обновить заказ" onAction="#handleUpdateStatus"/>
    <Button text="Удалить заказ" onAction="#handleDeleteOrder"/>
</VBox>