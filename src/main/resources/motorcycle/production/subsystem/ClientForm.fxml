<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="motorcycle.production.subsystem.ui.ClientFormController1">
    <Label text="Управление клиентами" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="ID клиента"/>
    <TextField fx:id="customerIdField"/>
    <Label text="ФИО"/>
    <TextField fx:id="nameField"/>
    <Label text="Контактная информация"/>
    <TextField fx:id="contactInfoField"/>
    <Button text="Создать клиента" onAction="#handleCreateClient"/>
    <Button text="Найти клиента" onAction="#handleFindClient"/>
    <Button text="Обновить клиента" onAction="#handleUpdateClient"/>
    <Button text="Удалить клиента" onAction="#handleDeleteClient"/>
</VBox>